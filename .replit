modules = ["nodejs-20", "python-3.12", "bash", "web", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-25_05"

[deployment]
deploymentTarget = "vm"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

[[ports]]
localPort = 5000
externalPort = 80
exposeLocalhost = true

[env]
PORT = "5000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[agent]
integrations = ["resend:1.0.0"]
expertMode = true

[userenv]

[userenv.development]
DEBUG_TOWER_PAYLOAD = "true"

[userenv.shared]
TOWER_ARTEFACT_JUDGE_STUB = "false"
WYSHBONE_DB_READY = "false"
DEEP_RESEARCH_OPT_IN_ONLY = "true"
TOWER_LOOP_CHAT_MODE = "true"
SUPERVISOR_EXECUTION_ENABLED = "true"
ENABLE_TOWER_DURING_RUN = "false"
MAX_REPLANS = "3"
