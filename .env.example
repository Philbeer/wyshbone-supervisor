# Wyshbone Supervisor Environment Variables

# ============================================
# ANTHROPIC API (Required for Autonomous Agent)
# ============================================
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ============================================
# DATABASE (Required)
# ============================================
DATABASE_URL=your-database-url

# ============================================
# SUPABASE (Required for production)
# ============================================
SUPABASE_URL=your-supabase-url
SUPABASE_KEY=your-supabase-anon-key

# ============================================
# TESTING (Optional)
# ============================================
# User ID for testing goal generator
TEST_USER_ID=user-123

# ============================================
# UNSPLASH (Optional — enables inline images in chat)
# ============================================
# Get your Access Key (NOT Secret Key) from: https://unsplash.com/developers
# Sign up for free, create an app, copy the Access Key
UNSPLASH_ACCESS_KEY=your-unsplash-access-key-here

# ============================================
# SERVER (Optional)
# ============================================
PORT=3001
NODE_ENV=development
